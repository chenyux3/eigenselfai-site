---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>EigenSelf</h1>
			<p>
				A generative framework for self-understanding — built around a short survey
				of the values that matter to you and how they connect, analyzed as a directed
				network, and rendered as a personal report.
			</p>
			<p>
				This site is where notes, essays, and excerpts about the framework live.
				The reports themselves are delivered privately.
			</p>
			<p>
				<a href="/blog">Read the writing →</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
